# Application settings (copy to .env and adjust)
FINUNDERWRITE_LOG_LEVEL=INFO
FINUNDERWRITE_DATA_RAW=data/raw
FINUNDERWRITE_DATA_INTERIM=data/interim
FINUNDERWRITE_DATA_PROCESSED=data/processed
FINUNDERWRITE_CONFIG_DIR=config

# Optional: override if not on PATH (Windows examples)
# FINUNDERWRITE_TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe
# FINUNDERWRITE_POPPLER_PATH=C:\Users\you\AppData\Local\Microsoft\WinGet\Packages\...\poppler-25.07.0\Library\bin

# Persistence (defaults to sqlite under data/processed)
# FINUNDERWRITE_DATABASE_URL=sqlite:///data/processed/finunderwrite.sqlite3

# API upload cap (bytes). Default 50 MB. Oversize errors report the limit in MB.
# FINUNDERWRITE_MAX_UPLOAD_BYTES=52428800
# Keep camelot off on Render (OpenCV OOM). Auto-disabled when RENDER is set.
# FINUNDERWRITE_ENABLE_CAMELOT_FALLBACK=false
# Cap sync PDF pages on free hosts (default 8 when RENDER is set).
# FINUNDERWRITE_MAX_SYNC_PDF_PAGES=8
# Optional: isolate PDF parse in a child process (off by default; can raise RSS).
# FINUNDERWRITE_ISOLATE_PDF_PARSE=false
# FINUNDERWRITE_PDF_PARSE_TIMEOUT_SECONDS=90

# Merchant categorizer
# FINUNDERWRITE_CATEGORIZER_MODEL_PATH=models/merchant_categorizer.joblib
# FINUNDERWRITE_CATEGORY_CONFIDENCE_THRESHOLD=0.5
# FINUNDERWRITE_MERCHANT_FUZZY_THRESHOLD=88

# Tier 3 LLM enrichment (OFF by default)
# FINUNDERWRITE_LLM_ENRICH_ENABLED=false
# FINUNDERWRITE_LLM_API_BASE=https://api.groq.com/openai/v1
# FINUNDERWRITE_LLM_MODEL=llama-3.1-8b-instant
# FINUNDERWRITE_LLM_API_KEY=
# FINUNDERWRITE_LLM_CONFIDENCE_THRESHOLD=0.5

# Live enrichment (offline batch)
# FINUNDERWRITE_ENRICHER=null
# FINUNDERWRITE_ENRICHMENT_API_BASE=
# FINUNDERWRITE_ENRICHMENT_TIMEOUT_SECONDS=3.0
# FINUNDERWRITE_ENRICHMENT_RATE_LIMIT_PER_SEC=1.0
# FINUNDERWRITE_ENRICHMENT_MAX_ATTEMPTS=3
# FINUNDERWRITE_RESPECT_ROBOTS=true
